PORT=3000

# Supported values: azure-sdk, nest-js-tools
USE_PACKAGE=azure-sdk
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://
FUND_TRANSACTION_TOPIC_NAME=topic.fund.transaction.test
FUND_TRANSACTION_SUBSCRIPTION_NAME=subscription.session.webhook.transaction.test
WEBHOOK_DELIVERY_QUEUE_NAME=webhook.delivery.test
FUND_PUBLISH_INTERVAL_MS=30000

# Optional scenario-test knobs
INSTANCE_ID=local-a
FUND_PUBLISH_ON_BOOTSTRAP_COUNT=1
FUND_FIXED_RESOURCE_IDENTIFIER=
FUND_STATUS_FLOW_MODE=off
FUND_STATUS_FLOW_RESOURCE_IDENTIFIER=
WEBHOOK_EVENT_PROCESSING_DELAY_MS=0
WEBHOOK_DELIVERY_FAIL_FIRST_ATTEMPTS=0
WEBHOOK_DELIVERY_PROCESSING_DELAY_MS=0

# Only used when USE_PACKAGE=nest-js-tools
MESSAGING_DEBUG=false
